{% extends "templates/base.njk" %}
{% from "partials/icons.njk" import fiddle, guitar, accordion, music_note, whistle, smallpipes, banjo, ukulele, music_group %}
{% set description = "Browse traditional Scottish music classes for adults in Edinburgh. Fiddle, guitar, accordion, whistle, song, smallpipes, banjo, ukulele and mixed instrument classes." %}
{% set canonical = "classes.html" %}

{% block content %}
<div class="page-hero">
  <div class="container">
    <h1>Classes</h1>
    <p>Traditional music and song classes for adults, all levels. Taught by ear in a relaxed, supportive environment.</p>
  </div>
</div>

<section style="position:relative;overflow:hidden;height:280px;background:#1a0a09;" aria-label="Banner image">
  <img src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=800&q=80" alt="Music ensemble rehearsal" loading="lazy" style="width:100%;height:100%;object-fit:cover;opacity:0.35;">
  <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(42,13,12,0.6) 0%,rgba(42,13,12,0.4) 100%);display:flex;align-items:center;justify-content:center;">
    <p style="font-family:var(--ff-display);font-size:clamp(1.2rem,2.5vw,1.6rem);font-weight:600;color:var(--clr-cream);text-align:center;max-width:600px;padding:0 var(--sp-lg);line-height:1.4;">Learn traditional Scottish music by ear in a relaxed, supportive environment</p>
  </div>
</section>

{# ===== ENROL CTA — Revenue-critical ===== #}
<section class="section section--warm section--compact">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:var(--sp-xl);flex-wrap:wrap;">
    <div>
      <p style="font-weight:700;color:var(--clr-maroon-deep);font-size:1.1rem;">Term 3 is open for booking</p>
      <p style="color:var(--clr-stone);font-size:0.9rem;">Early Bird pricing ends 7th April. 8-week term starts 21st April.</p>
    </div>
    <a href="https://www.scotsmusic.org/sign-in-3/" class="btn btn-primary btn-lg">Enrol Now <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
  </div>
</section>

{# ===== INSTRUMENT GRID ===== #}
<section class="section section--cream" aria-labelledby="instruments-heading">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Choose Your Instrument</span>
      <h2 id="instruments-heading" class="section-title">What would you like to play?</h2>
    </div>
    <div class="grid grid-3">
      {% set classes = [
        { name: 'Fiddle', icon: fiddle('icon icon-xl'), when: 'Thursday evenings', levels: 'All levels', desc: 'Multiple classes from beginner to advanced, all on the same night so you can find your level.' },
        { name: 'Guitar', icon: guitar('icon icon-xl'), when: 'Thursday evenings', levels: 'All levels', desc: 'Traditional guitar styles. Classes run on the same night as fiddle for easy level changes.' },
        { name: 'Accordion', icon: accordion('icon icon-xl'), when: 'Wednesday evenings', levels: 'All levels', desc: 'Piano accordion classes covering Scottish traditional repertoire.' },
        { name: 'Song', icon: music_note('icon icon-xl'), when: 'Tue daytime &amp; Thu evenings', levels: 'All welcome', desc: 'Learn traditional Scots songs. Daytime song sessions and evening classes available.' },
        { name: 'Whistle &amp; Flute', icon: whistle('icon icon-xl'), when: 'Thursday evenings', levels: 'All levels', desc: 'Tin whistle and wooden flute. A great starter instrument for beginners.' },
        { name: 'Scottish Smallpipes', icon: smallpipes('icon icon-xl'), when: 'Wednesday evenings', levels: 'All levels', desc: 'Bellows-blown Scottish smallpipes with experienced tutors.' },
        { name: '5-String Banjo', icon: banjo('icon icon-xl'), when: 'Short courses', levels: 'Varies', desc: 'Short courses available in Term 3 for banjo players.' },
        { name: 'Ukulele', icon: ukulele('icon icon-xl'), when: 'Thursday evenings', levels: 'Improver', desc: 'Improver-level ukulele focusing on traditional Scottish tunes.' },
        { name: 'Mixed Instrument', icon: music_group('icon icon-xl'), when: 'Tue, Wed &amp; Thu', levels: 'Multiple levels', desc: 'Bring any acoustic instrument. Sessions and slow sessions available at various levels.' }
      ] %}
      {% for cls in classes %}
      <div class="card reveal" style="overflow:hidden;">
        <div style="text-align:center;padding:var(--sp-lg) var(--sp-lg) 0;">
          <div style="font-size:2.5rem;margin-bottom:var(--sp-sm);" aria-hidden="true">{{ cls.icon | safe }}</div>
          <h3 style="font-family:var(--ff-display);font-size:1.25rem;font-weight:700;color:var(--clr-maroon-deep);">{{ cls.name | safe }}</h3>
        </div>
        <div class="card-body">
          <p style="margin-bottom:var(--sp-sm);">{{ cls.desc | safe }}</p>
          <div style="display:flex;gap:var(--sp-md);font-size:0.8rem;color:var(--clr-stone-light);flex-wrap:wrap;">
            <span>{{ cls.when | safe }}</span>
            <span>{{ cls.levels }}</span>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--warm section--compact" style="padding:0;">
  <div style="display:flex;height:180px;overflow:hidden;">
    <div style="flex:1;overflow:hidden;"><img src="https://images.unsplash.com/photo-1547153760-18fc86324498?w=600&q=80" alt="Violin being played" loading="lazy" style="width:100%;height:100%;object-fit:cover;"></div>
    <div style="flex:1;overflow:hidden;"><img src="https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=600&q=80" alt="Acoustic guitar" loading="lazy" style="width:100%;height:100%;object-fit:cover;"></div>
    <div style="flex:1;overflow:hidden;"><img src="https://images.unsplash.com/photo-1552422536-c46c849d4ce0?w=600&q=80" alt="String instrument detail" loading="lazy" style="width:100%;height:100%;object-fit:cover;"></div>
  </div>
</section>

{# ===== HOW CLASSES WORK ===== #}
<section class="section section--white" aria-labelledby="howto-heading">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Getting Started</span>
      <h2 id="howto-heading" class="section-title">How classes work</h2>
    </div>
    <div class="grid grid-2 reveal">
      <div class="card" style="overflow:visible;">
        <div class="card-body">
          <h3>Class structure</h3>
          <ul style="list-style:disc;padding-left:var(--sp-lg);">
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Open to <strong>anyone aged 18 or over</strong></li>
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Three terms: <strong>Term 1</strong> (12 wks, Sep), <strong>Term 2</strong> (10 wks, Jan), <strong>Term 3</strong> (8 wks, Apr)</li>
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Bring your own instrument to class</li>
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);"><strong>Learning by ear</strong> &mdash; tutors teach slowly at a pace suitable for the group</li>
            <li style="font-size:0.9rem;color:var(--clr-ink-soft);">Bring a recording device. Music also shared via photocopies or cloud storage.</li>
          </ul>
        </div>
      </div>
      <div class="card" style="overflow:visible;">
        <div class="card-body">
          <h3>Membership &amp; fees</h3>
          <ul style="list-style:disc;padding-left:var(--sp-lg);">
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Annual membership: <strong>&pound;20</strong> (&pound;15 concession)</li>
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Members get a <strong>discount on class fees</strong></li>
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Buy membership <em>before</em> classes to get the discount</li>
            <li style="margin-bottom:var(--sp-sm);font-size:0.9rem;color:var(--clr-ink-soft);">Membership is <strong>optional</strong> &mdash; runs 1 Aug to 31 Jul</li>
            <li style="font-size:0.9rem;color:var(--clr-ink-soft);">Save money with <strong>Early Bird rates</strong> each term</li>
          </ul>
          <div style="margin-top:var(--sp-lg);">
            <a href="/info.html#fees" class="btn btn-outline btn-sm">See full fee schedule</a>
          </div>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:var(--sp-xl);">
      <a href="https://www.scotsmusic.org/sign-in-3/" class="btn btn-primary btn-lg">Enrol for Term 3</a>
    </div>
  </div>
</section>
{% endblock %}
