{% from "partials/social-icons.njk" import icon as socialIcon %}
<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="logo-link" aria-label="{{ site.name }} home">
      <span class="logo-text">scots<span>music</span>group</span>
    </a>
    <button class="menu-toggle" aria-expanded="false" aria-controls="main-navigation" aria-label="Toggle menu">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18" stroke-linecap="round"/></svg>
    </button>
    <nav id="main-navigation" class="main-nav" aria-label="Main navigation">
      {% for item in site.nav %}
      <a href="{{ item.href }}"{% if item.id == pageId %} class="active"{% endif %}>{{ item.label }}</a>
      {% endfor %}
      <a href="/donate.html" class="nav-cta">Donate</a>
    </nav>
    <div class="header-social">
      <a href="{{ site.social.facebook }}" aria-label="Facebook">{{ socialIcon('facebook', 14) }}</a>
      <a href="{{ site.social.twitter }}" aria-label="X (Twitter)">{{ socialIcon('twitter', 12) }}</a>
      <a href="{{ site.social.youtube }}" aria-label="YouTube">{{ socialIcon('youtube', 14) }}</a>
      <a href="{{ site.social.instagram }}" aria-label="Instagram">{{ socialIcon('instagram', 14) }}</a>
    </div>
  </div>
</header>
