{% from "partials/social-icons.njk" import icon as socialIcon %}
{% from "partials/icons.njk" import map_pin, mail, phone %}
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="logo-text">scots<span>music</span>group</span>
        <p>A community-based charity offering traditional Scottish music and song classes for adults, sessions, monthly ceilidhs and social events in Edinburgh.</p>
        <div class="footer-social">
          <a href="{{ site.social.facebook }}" aria-label="Facebook">{{ socialIcon('facebook', 16) }}</a>
          <a href="{{ site.social.twitter }}" aria-label="X (Twitter)">{{ socialIcon('twitter', 16) }}</a>
          <a href="{{ site.social.youtube }}" aria-label="YouTube">{{ socialIcon('youtube', 16) }}</a>
          <a href="{{ site.social.instagram }}" aria-label="Instagram">{{ socialIcon('instagram', 16) }}</a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <a href="/classes.html">Classes</a>
        <a href="/ceilidhs.html">Ceilidhs &amp; Tickets</a>
        <a href="/info.html">Info &amp; Help</a>
        <a href="/community.html">Community</a>
        <a href="/shop.html">Shop</a>
        <a href="/donate.html">Donate</a>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <a href="/info.html#classfaq">Class FAQ</a>
        <a href="/info.html#dates">Term Dates</a>
        <a href="/info.html#fees">Fees &amp; Refunds</a>
        <a href="/info.html#membership">Membership</a>
        <a href="/info.html#privacy">Privacy Policy</a>
      </div>
      <div class="footer-col footer-contact">
        <h4>Contact</h4>
        <address>
          <div class="contact-item">
            <span class="contact-icon" aria-hidden="true">{{ map_pin('icon icon-sm') }}</span>
            <p>{{ site.name }}<br>{{ site.address.line1 }}<br>{{ site.address.line2 }}<br>{{ site.address.city }} {{ site.address.postcode }}</p>
          </div>
          <div class="contact-item">
            <span class="contact-icon" aria-hidden="true">{{ mail('icon icon-sm') }}</span>
            <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
          </div>
          <div class="contact-item">
            <span class="contact-icon" aria-hidden="true">{{ phone('icon icon-sm') }}</span>
            <p>{{ site.phone }}<br><small>{{ site.hours }}</small></p>
          </div>
        </address>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 {{ site.name }}. Registered charity {{ site.charity }}, Company {{ site.company }}.</p>
      <div class="footer-affiliates">
        <span>Traditional Music Forum</span>
        <span>&middot;</span>
        <span>OSCR Registered</span>
        <span>&middot;</span>
        <span>SCVO Member</span>
      </div>
    </div>
  </div>
</footer>
